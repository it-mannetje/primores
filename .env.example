# Copy this file to .env and fill in your values.
# .env is excluded from git and will never be committed.

# Flask session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Mail settings (used for magic link login emails)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=jouw@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Gmail App Password (not your login password)
MAIL_FROM=Canon Primores <jouw@gmail.com>

# Set to 1 during local development to print the magic link to the console
# instead of sending an email. Remove or set to 0 in production.
MAIL_DEBUG=0
